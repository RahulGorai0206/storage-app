{
  "name": "github-app",
  "version": "0.1.0",
  "private": true,
  "author": "Rahul Gorai <rahulgorai0206@gmail.com>",
  "description": "Next.js + Electron application for GitHub Drive management.",
  "main": "electron/dist/main.js",
  "scripts": {
    "dev:next": "next dev",
    "dev:electron": "npm run build:electron && wait-on http://localhost:3000 && electron .",
    "dev": "concurrently \"npm run dev:next\" \"npm run dev:electron\"",
    "build:next": "next build",
    "build:electron": "tsc -p electron/tsconfig.json",
    "build": "npm run build:next && npm run build:electron",
    "build:exe": "npm run build && electron-builder --win",
    "build:dist": "npm run build && electron-builder",
    "start": "next start",
    "lint": "eslint",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.github.drive",
    "productName": "GitHub Drive",
    "directories": {
      "output": "release"
    },
    "publish": {
      "provider": "github",
      "owner": "RahulGorai0206",
      "repo": "github-drive"
    },
    "files": [
      "out/**/*",
      "electron/dist/**/*",
      "public/**/*",
      "package.json",
      "!release/**/*",
      "!.git/**/*"
    ],
    "asarUnpack": [
      "**/*.node"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "public/icon.ico",
      "uninstallerIcon": "public/icon.ico",
      "license": "license.txt"
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "public/icon.png",
      "category": "public.app-category.utilities"
    },
    "dmg": {
      "contents": [
        {
          "x": 130,
          "y": 220
        },
        {
          "x": 410,
          "y": 220,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "public/icon.png"
    }
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/uuid": "^10.0.0",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.577.0",
    "next": "16.2.1",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.1.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "png-to-ico": "^3.0.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^9.0.4"
  }
}
